sequence:
  - variables:
      initial_state: "{{ states(entity) }}"
  - target:
      entity_id: "{{ entity }}"
    action: media_player.media_play_pause
  - delay: "00:00:03"
  - variables:
      current_state: "{{ states(entity) }}"
  - choose:
      - conditions:
          - condition: template
            value_template: "{{ initial_state == 'paused' }}"
          - condition: template
            value_template: "{{ current_state == 'playing' }}"
        sequence: []
      - conditions:
          - condition: template
            value_template: "{{ initial_state == 'playing' }}"
          - condition: template
            value_template: "{{ current_state == 'paused' }}"
        sequence: []
      - conditions:
          - condition: template
            value_template: "{{ initial_state == 'paused' }}"
          - condition: template
            value_template: "{{ current_state == 'paused' }}"
        sequence:
          - action: input_boolean.turn_on
            metadata: {}
            data: {}
            target:
              entity_id: input_boolean.homepod_play_{{user}}
      - conditions:
          - condition: template
            value_template: "{{ initial_state == 'idle' }}"
          - condition: template
            value_template: "{{ current_state == 'idle' }}"
        sequence:
          - action: input_boolean.turn_on
            metadata: {}
            data: {}
            target:
              entity_id: input_boolean.homepod_play_{{user}}
    default: []
alias: "homepod_play_pause_extended "
variables:
  entity: media_player.homepod_mini_gost
  user: stanislav
mode: parallel
description: ""
max: 10
